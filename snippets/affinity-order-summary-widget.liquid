{% comment %}
  Order Summary Widget — Recharge Affinity Integration
  Loads the cf-order-summary-widget.js Web Component and injects it into the
  Affinity portal overview header via data-recharge-slot.
  Rendered conditionally from layout/theme.liquid when the path contains /tools/recurring.

  The widget authenticates with the Recharge Storefront SDK (already initialized
  by recharge-affinity-homepage.liquid), fetches subscription, address, and payment
  data, then renders the order summary card.
{% endcomment %}

<script type="module">
  import CfOrderSummaryWidget from '{{ 'cf-order-summary-widget.js' | asset_url }}';
  if (!customElements.get('cf-order-summary-widget')) {
    customElements.define('cf-order-summary-widget', CfOrderSummaryWidget);
  }
</script>

<script type="text/html" data-recharge-slot="overview.header">
  <cf-order-summary-widget></cf-order-summary-widget>
</script>
