  .recharge-theme [role="tablist"] [role="tab"].active,
  .recharge-theme [role="tablist"] a[aria-selected="true"],
  .recharge-theme [role="tablist"] a[aria-current],
  .recharge-theme [role="tablist"] a.active,
  .recharge-theme [role="tablist"] button[aria-selected="true"],
  .recharge-theme [role="tablist"] button.active {
    background-color: #D9E8F4 !important;
  }

  .recharge-theme [role="tablist"] [role="tab"][aria-selected="true"]:hover,
  .recharge-theme [role="tablist"] a[aria-selected="true"]:hover,
  .recharge-theme [role="tablist"] a.active:hover,
  .recharge-theme [role="tablist"] button[aria-selected="true"]:hover,
  .recharge-theme [role="tablist"] button.active:hover {
    background-color: #D9E8F4 !important;
  }

  /* Tracker widget styles are encapsulated in the cf-tracker-widget Shadow DOM */

  /* --- Order status alert (green border) --- */
  .rc-alert--status {
    display: flex;
    flex-direction: row;
    align-items: center;
    gap: 10px;
    border-radius: 4px;
    padding: 8px 12px;
    background-color: #F2F7FB;
    border: 1px solid #5ABE8A;
  }

  .rc-alert--status__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 20px;
    height: 20px;
    flex-shrink: 0;
  }

  .rc-alert--status__icon svg {
    width: 17px;
    height: 17px;
    fill: #5ABE8A;
    color: #5ABE8A;
  }

  .rc-alert--status__text {
