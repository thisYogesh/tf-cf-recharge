{% comment %} ===================================================
   JavaScript: DOM restructuring + Recharge API
   =================================================== {% endcomment %}
<script>
(function() {
  'use strict';

  var SVG_CHECK = {{ svg_check_circle | json }};
  var SVG_SHARE = {{ svg_share_fat | json }};
  var SVG_CALENDAR = {{ svg_calendar_blank | json }};

  var DAYS = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
  var MONTHS = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun',
                'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];

  function formatDateStr(raw) {
    if (!raw) return '';
    var cleaned = raw
      .replace(/Your next order[:\s]*/i, '')
      .replace(/^(Processing|Scheduled|Queued|Shipping)\s*/i, '')
      .trim();
    var d = new Date(cleaned);
    if (isNaN(d.getTime())) return cleaned;
    return DAYS[d.getDay()] + ', ' + MONTHS[d.getMonth()] + ' ' +
           d.getDate() + ', ' + d.getFullYear();
  }

  function textOf(el) {
    return el ? el.textContent.trim() : '';
  }

  function findByText(root, match, opts) {
    var tag = (opts && opts.tag) || '*';
    var els = root.querySelectorAll(tag);
    for (var i = 0; i < els.length; i++) {
      var t = els[i].textContent.trim();
      if (typeof match === 'string' ? t.indexOf(match) !== -1 : match.test(t)) {
        return els[i];
      }
    }
    return null;
  }

  function closestDirectChild(el, ancestor) {
    var cur = el;
    while (cur && cur.parentElement !== ancestor) {
      cur = cur.parentElement;
    }
    return cur;
  }

  function findButtons(card) {
    var btns = card.querySelectorAll('button, a.recharge-button, [class*="recharge-button"], [class*="rc_btn"], [class*="rc-btn"]');
    var send = null;
    var reschedule = null;
    for (var i = 0; i < btns.length; i++) {
      var t = btns[i].textContent.trim().toLowerCase();
      if (t.indexOf('send') !== -1) send = btns[i];
      else if (t.indexOf('reschedule') !== -1) reschedule = btns[i];
    }
    return { send: send, reschedule: reschedule };
  }

  function findProductName(card) {
    var itemsEl = findByText(card, 'In your order');
    if (!itemsEl) return '';
    var section = closestDirectChild(itemsEl, card) || itemsEl.parentElement;
    if (!section) return '';
    var links = section.querySelectorAll('a, [class*="title"], [class*="name"], [class*="product"]');
    for (var i = 0; i < links.length; i++) {
      var t = links[i].textContent.trim();
      if (t && t !== 'In your order' && t !== 'Edit' && t.length > 2 && t.indexOf('$') === -1 && t.indexOf('Every') === -1) {
        return t;
      }
    }
    var spans = section.querySelectorAll('span, p, div');
    for (var i = 0; i < spans.length; i++) {
      var t = spans[i].textContent.trim();
      if (t && t !== 'In your order' && t !== 'Edit' && t.length > 3 &&
          t.indexOf('$') === -1 && t.indexOf('Every') === -1 &&
          t.indexOf('saving') === -1 && spans[i].children.length === 0) {
        return t;
      }
    }
    return '';
  }

  function findDateText(card) {
    var dateRe = /\b(Jan|Feb|Mar|Apr|May|Jun|Jul|Aug|Sep|Oct|Nov|Dec)\b/i;
    var all = card.querySelectorAll('*');
    for (var i = 0; i < all.length; i++) {
      if (all[i].children.length > 0) continue;
      var t = all[i].textContent.trim();
      if (dateRe.test(t) && /\d{4}/.test(t) &&
          t.indexOf('next order') === -1 && t.indexOf('In your order') === -1) {
        return t;
      }
    }
    var heading = card.querySelector('.recharge-heading, h1, h2, h3');
    if (heading) return heading.textContent.trim();
    return '';
  }

  function findAlertText(card) {
    var el = findByText(card, /saving|arrive|replace on schedule|on time/i);
    if (el) return el.textContent.trim();
    return 'Your next order is set to arrive in time to replace on schedule.';
  }

  function buildOverlayCard(dateText, productName, alertText, realSendBtn, realRescheduleBtn) {
    var alertDiv = document.createElement('div');
    alertDiv.setAttribute('data-cf-section', 'alert');
    alertDiv.innerHTML = '<span class="cf-alert-icon">' + SVG_CHECK + '</span>' +
                         '<span class="cf-alert-text">' + alertText + '</span>';

    var headerDiv = document.createElement('div');
    headerDiv.setAttribute('data-cf-section', 'header');
    var labelEl = document.createElement('p');
    labelEl.className = 'cf-order-label';
    labelEl.textContent = 'Your next order';
    var dateEl = document.createElement('p');
    dateEl.className = 'cf-order-date';
    dateEl.textContent = formatDateStr(dateText);
    headerDiv.appendChild(labelEl);
    headerDiv.appendChild(dateEl);
    if (productName) {
      var prodEl = document.createElement('p');
      prodEl.className = 'cf-order-product';
      prodEl.textContent = productName;
      headerDiv.appendChild(prodEl);
    }

    var ctaDiv = document.createElement('div');
    ctaDiv.setAttribute('data-cf-section', 'ctas');

    var sendEl = document.createElement('button');
    sendEl.className = 'cf-btn-primary';
    sendEl.type = 'button';
    sendEl.innerHTML = SVG_SHARE + ' Send Now';
    sendEl.addEventListener('click', function(e) {
      e.preventDefault();
      if (realSendBtn) realSendBtn.click();
    });

    var rescheduleEl = document.createElement('button');
    rescheduleEl.className = 'cf-btn-secondary';
    rescheduleEl.type = 'button';
    rescheduleEl.innerHTML = SVG_CALENDAR + ' Reschedule';
    rescheduleEl.addEventListener('click', function(e) {
      e.preventDefault();
      if (realRescheduleBtn) realRescheduleBtn.click();
    });

    ctaDiv.appendChild(sendEl);
    ctaDiv.appendChild(rescheduleEl);

    return { alert: alertDiv, header: headerDiv, ctas: ctaDiv };
  }

  function transformCard(card) {
    if (card.getAttribute('data-cf-overview') === 'done') return;

    var cardText = card.textContent;
    if (cardText.indexOf('next order') === -1 && cardText.indexOf('Send now') === -1 && cardText.indexOf('Send Now') === -1) return;

    var btns = findButtons(card);
    if (!btns.send && !btns.reschedule) return;

    var dateText = findDateText(card);
    var productName = findProductName(card);
    var alertText = findAlertText(card);

    card.setAttribute('data-cf-overview', 'done');

    var hidden = document.createElement('div');
    hidden.setAttribute('data-cf-section', 'original');
    hidden.style.cssText = 'display:none!important;position:absolute!important;width:0!important;height:0!important;overflow:hidden!important;pointer-events:none!important;';
    while (card.firstChild) {
      hidden.appendChild(card.firstChild);
    }
    card.appendChild(hidden);

    var parts = buildOverlayCard(dateText, productName, alertText, btns.send, btns.reschedule);
    card.appendChild(parts.alert);
    card.appendChild(parts.header);
    card.appendChild(parts.ctas);
  }

  function updateProductName(name) {
    if (!name) return;
    var header = document.querySelector('[data-cf-section="header"]');
    if (!header) return;
    var existing = header.querySelector('.cf-order-product');
    if (existing) {
      existing.textContent = name;
    } else {
      var el = document.createElement('p');
      el.className = 'cf-order-product';
      el.textContent = name;
      header.appendChild(el);
    }
  }

  function scan() {
    var cards = document.querySelectorAll('.recharge-card, [class*="rc_card"], [class*="rc-card"], [class*="recharge-order"]');
    for (var i = 0; i < cards.length; i++) {
      transformCard(cards[i]);
    }
  }

  var rafId = 0;
  function debouncedScan() {
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(scan);
  }

  scan();

  var observer = new MutationObserver(function(mutations) {
    var dominated = false;
    for (var i = 0; i < mutations.length; i++) {
      if (mutations[i].addedNodes.length > 0) { dominated = true; break; }
    }
    if (dominated) debouncedScan();
  });
  observer.observe(document.body || document.documentElement, {
    childList: true,
    subtree: true
  });

  /* -------------------------------------------------
     Recharge API helper (for tracker widget + welcome)
     ------------------------------------------------- */
  var rcAPI = {
    session: null,
    authenticate: function() {
      if (this.session) return Promise.resolve(this.session);
      return recharge.auth.loginCustomerPortal()
        .then(function(s) { rcAPI.session = s; return s; })
        .catch(function(err) { console.error('[RC Portal] Auth failed:', err); throw err; });
    },
    getSubscriptions: function() {
      return recharge.subscription.listSubscriptions(this.session, {
        limit: 25, sort_by: 'id-asc', status: 'Active'
      }).then(function(res) { return res.subscriptions || []; })
        .catch(function() { return []; });
    }
  };

  function formatShortDate(dateStr) {
    if (!dateStr) return '---';
    var d = new Date(dateStr);
    if (isNaN(d.getTime())) return '---';
    return MONTHS[d.getMonth()] + ' ' + d.getDate();
  }

  function daysBetween(a, b) {
    var da = new Date(a), db = new Date(b);
    return Math.max(0, Math.ceil((db - da) / 86400000));
  }

  function initTrackerAndProductName() {
    rcAPI.authenticate().then(function() {
      return rcAPI.getSubscriptions();
    }).then(function(subs) {
      if (!subs.length) return;

      var sub = subs[0];

      var prodTitle = sub.product_title || '';
      if (prodTitle) updateProductName(prodTitle);

      var widget = document.querySelector('cf-tracker-widget');
      if (!widget) return;

      var today = new Date();
      var nextCharge = sub.next_charge_scheduled_at;
      var LIFESPAN = 30;

      if (nextCharge) {
        var daysLeft = daysBetween(today, nextCharge);
        var nextDate = new Date(nextCharge);
        var delivered = new Date(nextDate);
        delivered.setDate(delivered.getDate() - LIFESPAN);

        widget.setAttribute('days-left', String(daysLeft));
        widget.setAttribute('total-days', String(LIFESPAN));
        widget.setAttribute('delivered-date', formatShortDate(delivered.toISOString()));
        widget.setAttribute('replace-date', formatShortDate(nextCharge));

        var dM = delivered.getMonth() + 1;
        var dD = delivered.getDate();
        widget.setAttribute('alert-message',
          'According to our records, your filter was delivered on ' + dM + '/' + dD +
          '. If you did not replace on that date, you can reset your filter health below.');
      }
    }).catch(function(err) {
      console.error('[RC Portal] Tracker init failed:', err);
    });
  }

  function initWelcome() {
    rcAPI.authenticate().then(function() {
      var heading = document.getElementById('rc-welcome-heading');
      if (heading && rcAPI.session && rcAPI.session.customer) {
        var name = rcAPI.session.customer.first_name || '';
        if (name) heading.textContent = 'Welcome back, ' + name + '!';
      }
    }).catch(function() {});
  }

  document.addEventListener('Recharge::slot::mounted', function(event) {
    var name = event.detail && event.detail.name;
    if (name === 'sidebar' || name === 'header') {
      initTrackerAndProductName();
      if (name === 'header') initWelcome();
    }
  });

  document.addEventListener('Recharge::action::orderChanged', function() {
    initTrackerAndProductName();
    var cards = document.querySelectorAll('[data-cf-overview="done"]');
    cards.forEach(function(c) { c.removeAttribute('data-cf-overview'); });
    debouncedScan();
  });
})();
</script>
