    border-radius: 4px;
    background: #FFFFFF;
    box-shadow: none;
    padding: 18px 18px 22px;
  }

  /* --- Portal-scoped header border --- */
  .header {
    border-bottom: 1px solid #D9E8F4;
  }

  /* --- Native portal link styling --- */
  .recharge-card a {
    color: #2C70BB;
  }

  .recharge-card a[href*='edit'],
  .recharge-card a[href*='address'],
  .recharge-card a[href*='payment'] {
    text-decoration: underline;
    color: #2C70BB;
  }

  /* =============================================
     (E) Next Order Card — Figma-Matched Overrides
     ============================================= */

  /* --- Primary button (Send Now, Add product, etc.) --- */
  .recharge-button {
    background-color: #2C70BB;
    color: #FFFFFF;
    border: 2px solid #2C70BB;
    border-radius: 100px;
    font-family: 'FT System', var(--font-body--family), sans-serif;
    font-size: 14px;
    line-height: normal;
    font-weight: 400;
    padding: 13px 24px 14px;
    min-height: 46px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    cursor: pointer;
    text-decoration: none;
    transition: background-color 0.15s ease, border-color 0.15s ease;
    box-sizing: border-box;
  }

  .recharge-button:hover {
    background-color: #235a96;
    border-color: #235a96;
  }

  /* --- Secondary / outline button (Reschedule) --- */
  .recharge-button--secondary,
  .recharge-button--outline,
  .recharge-button[class*="secondary"],
  .recharge-button[class*="outline"] {
    background-color: #FFFFFF !important;
    color: #202635 !important;
    border: 1px solid #202635 !important;
    border-radius: 57px !important;
  }

  .recharge-button--secondary:hover,
  .recharge-button--outline:hover,
  .recharge-button[class*="secondary"]:hover,
  .recharge-button[class*="outline"]:hover {
    background-color: #f0f4f8 !important;
  }

  /* --- Status / savings alert (green border, light bg) --- */
  .recharge-card [class*="alert"],
  .recharge-card [class*="savings"],
  .recharge-card [class*="info-banner"],
  .recharge-card [class*="notification"] {
    background-color: #F2F7FB !important;
    border: 1px solid #5ABE8A !important;
    border-radius: 4px !important;
    padding: 8px 12px !important;
    display: flex !important;
    align-items: center !important;
    gap: 10px !important;
    font-size: 14px !important;
    line-height: 1.5 !important;
    color: #202635 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
  }

  .recharge-card [class*="alert"] svg,
  .recharge-card [class*="savings"] svg,
  .recharge-card [class*="notification"] svg {
    width: 20px !important;
    height: 20px !important;
    flex-shrink: 0 !important;
    fill: #5ABE8A !important;
    color: #5ABE8A !important;
  }

  /* --- Next order heading hierarchy --- */
  /* "Your next order" label should be small and gray */
  .recharge-card [class*="next-order"] [class*="label"],
  .recharge-card [class*="next-order"] [class*="subtitle"],
  .recharge-card [class*="order-header"] [class*="label"],
  .recharge-card > [class*="header"] [class*="sub"],
  .recharge-card [class*="sub-heading"] {
    font-size: 18px !important;
    line-height: 1.4 !important;
    color: #797D86 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
  }

  /* Date should be large and prominent */
  .recharge-card [class*="next-order"] .recharge-heading,
  .recharge-card [class*="order-header"] .recharge-heading,
  .recharge-card > [class*="header"] .recharge-heading {
    font-size: 36px !important;
    line-height: 1.3 !important;
    letter-spacing: -0.36px !important;
    color: #202635 !important;
    font-weight: 300 !important;
    font-family: 'FT System', var(--font-heading--family), sans-serif !important;
  }

  /* Product name under date */
  .recharge-card [class*="next-order"] [class*="product-name"],
  .recharge-card [class*="next-order"] [class*="product-title"] {
    font-size: 20px !important;
    line-height: 1.3 !important;
    letter-spacing: -0.2px !important;
    color: #202635 !important;
    padding-top: 4px !important;
  }

  /* --- CTA button group (Send Now + Reschedule side by side) --- */
  .recharge-card [class*="action"],
  .recharge-card [class*="button-group"],
  .recharge-card [class*="cta-group"],
  .recharge-card [class*="buttons"] {
    display: flex !important;
    gap: 12px !important;
    width: 100% !important;
  }

  .recharge-card [class*="action"] .recharge-button,
  .recharge-card [class*="button-group"] .recharge-button,
  .recharge-card [class*="cta-group"] .recharge-button,
  .recharge-card [class*="buttons"] .recharge-button {
    flex: 1 !important;
    min-width: 0 !important;
  }
</style>

