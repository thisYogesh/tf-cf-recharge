{% comment %} =============================================
   JavaScript: Recharge SDK + Tracker Widget Logic
   ============================================= {% endcomment %}
<script>
(function() {
  'use strict';

  /* -------------------------------------------------
     Recharge API helper
     ------------------------------------------------- */
  const rcAPI = {
    session: null,

    async authenticate() {
      if (this.session) return this.session;
      try {
        this.session = await recharge.auth.loginCustomerPortal();
        return this.session;
      } catch (err) {
        console.error('[RC Portal] Authentication failed:', err);
        throw err;
      }
    },

    async getSubscriptions() {
      try {
        const res = await recharge.subscription.listSubscriptions(this.session, {
          limit: 25,
          sort_by: 'id-asc',
          status: 'Active'
        });
        return res.subscriptions || [];
      } catch (err) {
        console.error('[RC Portal] Failed to fetch subscriptions:', err);
        return [];
      }
    }
  };

  /* -------------------------------------------------
     Date formatting helpers
     ------------------------------------------------- */
  function formatShortDate(dateStr) {
    if (!dateStr) return '---';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '---';
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return months[d.getMonth()] + ' ' + d.getDate();
  }

  function daysBetween(dateA, dateB) {
    const a = new Date(dateA);
    const b = new Date(dateB);
    const diffMs = b.getTime() - a.getTime();
    return Math.max(0, Math.ceil(diffMs / (1000 * 60 * 60 * 24)));
  }

  /* -------------------------------------------------
     Tracker Web Component — feed Recharge data into
     <cf-tracker-widget> attributes
     ------------------------------------------------- */
  async function initTrackerWidget() {
    try {
      await rcAPI.authenticate();
      const subscriptions = await rcAPI.getSubscriptions();

      const widget = document.querySelector('cf-tracker-widget');
      if (!widget) return;

      if (!subscriptions.length) {
        widget.style.display = 'none';
        return;
      }

      const sub = subscriptions[0];
      const today = new Date();
      const nextCharge = sub.next_charge_scheduled_at;
      const FILTER_LIFESPAN_DAYS = 30;

      if (nextCharge) {
        const daysLeft = daysBetween(today, nextCharge);
        const nextDate = new Date(nextCharge);
        const deliveredDate = new Date(nextDate);
        deliveredDate.setDate(deliveredDate.getDate() - FILTER_LIFESPAN_DAYS);

        widget.setAttribute('days-left', String(daysLeft));
        widget.setAttribute('total-days', String(FILTER_LIFESPAN_DAYS));
        widget.setAttribute('delivered-date', formatShortDate(deliveredDate.toISOString()));
        widget.setAttribute('replace-date', formatShortDate(nextCharge));

        const dMonth = deliveredDate.getMonth() + 1;
        const dDay = deliveredDate.getDate();
        widget.setAttribute('alert-message',
          'According to our records, your filter was delivered on ' + dMonth + '/' + dDay + '. If you did not replace on that date, you can reset your filter health below.');
      }
    } catch (err) {
      console.error('[RC Portal] Tracker widget init failed:', err);
    }
  }

  /* -------------------------------------------------
     Welcome greeting
     ------------------------------------------------- */
  async function initWelcome() {
    try {
      await rcAPI.authenticate();
      const heading = document.getElementById('rc-welcome-heading');
      if (heading && rcAPI.session && rcAPI.session.customer) {
        const firstName = rcAPI.session.customer.first_name || '';
        if (firstName) {
          heading.textContent = 'Welcome back, ' + firstName + '!';
        }
      }
    } catch (err) {
      /* Silently fail — greeting stays as "Welcome back!" */
    }
  }

  /* -------------------------------------------------
     Event listeners
     ------------------------------------------------- */

  document.addEventListener('Recharge::slot::mounted', function(event) {
    const name = event.detail && event.detail.name;

    if (name === 'sidebar') {
      initTrackerWidget();
    }

    if (name === 'header') {
      initWelcome();
    }
  });

  document.addEventListener('Recharge::action::orderChanged', function() {
    initTrackerWidget();
  });
})();
</script>
