{% comment %} =============================================
   JavaScript: Recharge SDK + Tracker Widget Logic
   ============================================= {% endcomment %}
<script>
(function() {
  'use strict';

  /* -------------------------------------------------
     Recharge API helper
     ------------------------------------------------- */
  const rcAPI = {
    session: null,

    async authenticate() {
      if (this.session) return this.session;
      try {
        this.session = await recharge.auth.loginCustomerPortal();
        return this.session;
      } catch (err) {
        console.error('[RC Portal] Authentication failed:', err);
        throw err;
      }
    },

    async getSubscriptions() {
      try {
        const res = await recharge.subscription.listSubscriptions(this.session, {
          limit: 25,
          sort_by: 'id-asc',
          status: 'Active'
        });
        return res.subscriptions || [];
      } catch (err) {
        console.error('[RC Portal] Failed to fetch subscriptions:', err);
        return [];
      }
    }
  };

  /* -------------------------------------------------
     SVG arc calculation
     ------------------------------------------------- */
  function updateArcProgress(daysLeft, totalDays) {
    const arcEl = document.getElementById('rc-arc-progress');
    if (!arcEl) return;

    const totalLength = 393; /* approximate arc length for the semicircle */
    const pct = Math.max(0, Math.min(1, daysLeft / totalDays));
    const offset = totalLength * (1 - pct);

    arcEl.setAttribute('stroke-dasharray', String(totalLength));
    arcEl.setAttribute('stroke-dashoffset', String(offset));

    /* Color transition: green > yellow > red */
    let strokeColor = '#5ABE8A';
    if (pct <= 0.25) {
      strokeColor = '#E74C3C';
    } else if (pct <= 0.5) {
      strokeColor = '#F5A623';
    }
    arcEl.setAttribute('stroke', strokeColor);
  }

  /* -------------------------------------------------
     Date formatting helpers
     ------------------------------------------------- */
  function formatShortDate(dateStr) {
    if (!dateStr) return '---';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '---';
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return months[d.getMonth()] + ' ' + d.getDate();
  }

  function formatLongDate(dateStr) {
    if (!dateStr) return '---';
    const d = new Date(dateStr);
    if (isNaN(d.getTime())) return '---';
    const days = ['Sun', 'Mon', 'Tue', 'Wed', 'Thu', 'Fri', 'Sat'];
    const months = ['Jan', 'Feb', 'Mar', 'Apr', 'May', 'Jun', 'Jul', 'Aug', 'Sep', 'Oct', 'Nov', 'Dec'];
    return days[d.getDay()] + ', ' + months[d.getMonth()] + ' ' + d.getDate() + ', ' + d.getFullYear();
  }

  function daysBetween(dateA, dateB) {
    const a = new Date(dateA);
    const b = new Date(dateB);
    const diffMs = b.getTime() - a.getTime();
    return Math.max(0, Math.ceil(diffMs / (1000 * 60 * 60 * 24)));
  }

  /* -------------------------------------------------
     Tracker widget initialization
     ------------------------------------------------- */
  async function initTracker() {
    try {
      await rcAPI.authenticate();
      const subscriptions = await rcAPI.getSubscriptions();

      if (!subscriptions.length) {
        const tracker = document.getElementById('rc-tracker');
        if (tracker) tracker.style.display = 'none';
        return;
      }

      /* Find the first subscription (filter product) */
      const sub = subscriptions[0];

      /* Calculate days remaining */
      const today = new Date();
      const nextCharge = sub.next_charge_scheduled_at;
      const FILTER_LIFESPAN_DAYS = 30;
      let daysLeft = 0;

      if (nextCharge) {
        daysLeft = daysBetween(today, nextCharge);
      }

      /* Update counter */
      const counterEl = document.getElementById('rc-days-count');
      if (counterEl) {
        counterEl.textContent = String(daysLeft);
      }

      /* Update arc */
      updateArcProgress(daysLeft, FILTER_LIFESPAN_DAYS);

      /* Update dates */
      const deliveredEl = document.getElementById('rc-date-delivered');
      const replaceEl = document.getElementById('rc-date-replace');

      /* Estimate delivered date as nextCharge - FILTER_LIFESPAN_DAYS */
      if (nextCharge) {
        const nextDate = new Date(nextCharge);
        const deliveredDate = new Date(nextDate);
        deliveredDate.setDate(deliveredDate.getDate() - FILTER_LIFESPAN_DAYS);

        if (deliveredEl) {
          deliveredEl.innerHTML = 'Delivered<br>' + formatShortDate(deliveredDate.toISOString());
        }
        if (replaceEl) {
          replaceEl.innerHTML = 'Replace By<br>' + formatShortDate(nextCharge);
        }
      }

      /* Update filter alert text */
      const alertText = document.getElementById('rc-filter-alert-text');
      if (alertText && nextCharge) {
        const nextDate = new Date(nextCharge);
        const deliveredDate = new Date(nextDate);
        deliveredDate.setDate(deliveredDate.getDate() - FILTER_LIFESPAN_DAYS);
        const dMonth = deliveredDate.getMonth() + 1;
        const dDay = deliveredDate.getDate();
        alertText.textContent = 'According to our records, your filter was delivered on ' + dMonth + '/' + dDay + '. If you did not replace on that date, you can reset your filter health below.';
      }

    } catch (err) {
      console.error('[RC Portal] Tracker init failed:', err);
    }
  }

  /* -------------------------------------------------
     Welcome greeting
     ------------------------------------------------- */
  async function initWelcome() {
    try {
      await rcAPI.authenticate();
      const heading = document.getElementById('rc-welcome-heading');
      if (heading && rcAPI.session && rcAPI.session.customer) {
        const firstName = rcAPI.session.customer.first_name || '';
        if (firstName) {
          heading.textContent = 'Welcome back, ' + firstName + '!';
        }
      }
    } catch (err) {
      /* Silently fail — greeting stays as "Welcome back!" */
    }
  }

  /* -------------------------------------------------
     Alert dismiss handler
     ------------------------------------------------- */
  function initAlertDismiss() {
    const closeBtn = document.getElementById('rc-filter-alert-close');
    if (closeBtn) {
      closeBtn.addEventListener('click', function() {
        const alert = document.getElementById('rc-filter-alert');
        if (alert) alert.style.display = 'none';
      });
    }
  }

  /* -------------------------------------------------
     Event listeners
     ------------------------------------------------- */

  /* Initialize when sidebar slot mounts */
  document.addEventListener('Recharge::slot::mounted', function(event) {
    const name = event.detail && event.detail.name;

    if (name === 'sidebar') {
      initTracker();
      initAlertDismiss();
    }

    if (name === 'header') {
      initWelcome();
    }
  });

  /* Re-initialize tracker when order changes */
  document.addEventListener('Recharge::action::orderChanged', function() {
    initTracker();
  });
})();
</script>
