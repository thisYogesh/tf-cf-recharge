<style>
  /* ===================================================
     Recharge CSS Variable Overrides (brand theming)
     =================================================== */
  .recharge-theme {
    --recharge-app-background: #F2F7FB;
    --recharge-views-background: #F2F7FB;
    --recharge-cards-background: #FFFFFF;
    --recharge-cards-border-color: #D9E8F4;
    --recharge-button-brand: #2C70BB;
    --recharge-button-color: #FFFFFF;
    --recharge-button-border-radius: 100px;
    --recharge-corners-radius: 4px;
    --recharge-typography-heading-font-family: 'FT System', var(--font-heading--family), sans-serif;
    --recharge-typography-body-font-family: 'FT System', var(--font-body--family), sans-serif;
    --recharge-color-brand: #2C70BB;
    --recharge-color-brand-120: #235a96;
    --recharge-color-brand-85: #D9E8F4;
    --recharge-color-brand-75: #c5dced;
  }

  /* ===================================================
     Navigation Tabs — horizontal pill tabs
     =================================================== */
  .recharge-theme [role="tablist"] {
    display: flex !important;
    flex-direction: row !important;
    gap: 8px !important;
    overflow-x: auto !important;
    padding-bottom: 8px !important;
    -webkit-overflow-scrolling: touch !important;
    scrollbar-width: none !important;
  }
  .recharge-theme [role="tablist"]::-webkit-scrollbar { display: none; }

  .recharge-theme [role="tablist"] [role="tab"],
  .recharge-theme [role="tablist"] a,
  .recharge-theme [role="tablist"] button {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    border-radius: 60px !important;
    padding: 10px 24px 12px !important;
    border: 1px solid #202635 !important;
    font-size: 14px !important;
    line-height: 20px !important;
    white-space: nowrap !important;
    color: #202635 !important;
    background-color: #FFFFFF !important;
    text-decoration: none !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    font-weight: 400 !important;
    cursor: pointer !important;
  }
  .recharge-theme [role="tablist"] [role="tab"]:hover,
  .recharge-theme [role="tablist"] a:hover,
  .recharge-theme [role="tablist"] button:hover {
    background-color: #f0f4f8 !important;
  }
  .recharge-theme [role="tablist"] [role="tab"][aria-selected="true"],
  .recharge-theme [role="tablist"] a[aria-selected="true"],
  .recharge-theme [role="tablist"] a[aria-current],
  .recharge-theme [role="tablist"] a.active,
  .recharge-theme [role="tablist"] button[aria-selected="true"],
  .recharge-theme [role="tablist"] button.active {
    background-color: #D9E8F4 !important;
  }

  /* ===================================================
     Welcome Heading
     =================================================== */
  .rc-welcome {
    font-size: 26px;
    line-height: 34px;
    letter-spacing: -0.52px;
    color: #202635;
    font-weight: 400;
    font-family: 'FT System', var(--font-heading--family), sans-serif;
    margin: 0;
  }

  /* ===================================================
     Base card styling (Recharge stable classes)
     =================================================== */
  .recharge-heading {
    font-family: 'FT System', var(--font-heading--family), sans-serif !important;
    color: #202635 !important;
    font-weight: 400 !important;
  }
  .recharge-text {
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    color: #202635 !important;
  }
  .recharge-card {
    border: 1px solid #D9E8F4 !important;
    border-radius: 4px !important;
    background: #FFFFFF !important;
    box-shadow: none !important;
  }
  .recharge-card a {
    color: #2C70BB;
  }

  /* ===================================================
     TRANSFORMED CARD — [data-cf-overview] structural CSS
     Applied after JS marks the DOM sections
     =================================================== */
  [data-cf-overview] {
    display: flex !important;
    flex-direction: column !important;
    gap: 16px !important;
    padding: 22px 18px !important;
  }

  /* Section ordering: alert(1) → header(2) → ctas(3) → rest hidden */
  [data-cf-overview] > [data-cf-section="alert"]  { order: 1 !important; }
  [data-cf-overview] > [data-cf-section="header"] { order: 2 !important; }
  [data-cf-overview] > [data-cf-section="ctas"]   { order: 3 !important; }

  /* Hide "In your order" product items section */
  [data-cf-overview] > [data-cf-section="items"] {
    display: none !important;
  }
  /* Hide any remaining direct children not marked */
  [data-cf-overview] > *:not([data-cf-section]) {
    display: none !important;
  }

  /* --- Alert banner --- */
  [data-cf-section="alert"] {
    display: flex !important;
    flex-direction: row !important;
    align-items: center !important;
    gap: 10px !important;
    background-color: #F2F7FB !important;
    border: 1px solid #5ABE8A !important;
    border-radius: 4px !important;
    padding: 8px 12px !important;
    width: 100% !important;
    box-sizing: border-box !important;
  }
  [data-cf-section="alert"] .cf-alert-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    width: 20px;
    height: 20px;
  }
  [data-cf-section="alert"] .cf-alert-text {
    font-size: 14px !important;
    line-height: 1.5 !important;
    color: #202635 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    font-weight: 400 !important;
    flex: 1;
    min-width: 0;
  }

  /* --- Header text section --- */
  [data-cf-section="header"] {
    display: flex !important;
    flex-direction: column !important;
    align-items: flex-start !important;
    width: 100% !important;
  }

  /* "Your next order" label */
  .cf-order-label {
    font-size: 18px !important;
    line-height: 1.4 !important;
    color: #797D86 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Large date heading */
  .cf-order-date {
    font-size: 36px !important;
    line-height: 1.3 !important;
    letter-spacing: -0.36px !important;
    color: #202635 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-heading--family), sans-serif !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* Product name */
  .cf-order-product {
    font-size: 20px !important;
    line-height: 1.3 !important;
    letter-spacing: -0.2px !important;
    color: #202635 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    padding-top: 4px !important;
    margin: 0 !important;
  }

  /* --- CTA Buttons container --- */
  [data-cf-section="ctas"] {
    display: flex !important;
    flex-direction: row !important;
    gap: 12px !important;
    width: 100% !important;
  }

  /* Primary CTA — Send Now (blue filled) */
  .cf-btn-primary {
    flex: 1 !important;
    min-width: 0 !important;
    background-color: #2C70BB !important;
    color: #FFFFFF !important;
    border: 2px solid #2C70BB !important;
    border-radius: 100px !important;
    padding: 13px 24px 14px !important;
    min-height: 46px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 8px !important;
    font-size: 14px !important;
    line-height: normal !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    cursor: pointer !important;
    text-decoration: none !important;
    box-sizing: border-box !important;
    white-space: nowrap !important;
  }
  .cf-btn-primary:hover {
    background-color: #235a96 !important;
    border-color: #235a96 !important;
  }
  .cf-btn-primary svg {
    flex-shrink: 0;
  }

  /* Secondary CTA — Reschedule (outline) */
  .cf-btn-secondary {
    flex: 1 !important;
    min-width: 0 !important;
    background-color: #FFFFFF !important;
    color: #202635 !important;
    border: 1px solid #202635 !important;
    border-radius: 57px !important;
    padding: 10px 28px 13px !important;
    min-height: 46px !important;
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 6px !important;
    font-size: 14px !important;
    line-height: normal !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    cursor: pointer !important;
    text-decoration: none !important;
    box-sizing: border-box !important;
    white-space: nowrap !important;
  }
  .cf-btn-secondary:hover {
    background-color: #f0f4f8 !important;
  }
  .cf-btn-secondary svg {
    flex-shrink: 0;
  }

  /* ===================================================
     Responsive — Mobile (matches Figma 762:6327)
     =================================================== */
  @media screen and (max-width: 767px) {
    .rc-welcome {
      font-size: 22px;
      line-height: 29px;
    }
    .cf-order-label {
      font-size: 14px !important;
      line-height: 1.4 !important;
      letter-spacing: -0.14px !important;
    }
    .cf-order-date {
      font-size: 22px !important;
      line-height: 1.3 !important;
      letter-spacing: -0.22px !important;
    }
    .cf-order-product {
      font-size: 16px !important;
      line-height: 1.3 !important;
      letter-spacing: -0.16px !important;
      font-family: 'Inter', system-ui, sans-serif !important;
    }
    [data-cf-section="alert"] .cf-alert-text {
      font-size: 12px !important;
      line-height: 1.3 !important;
      font-weight: 500 !important;
    }
    [data-cf-section="ctas"] {
      flex-direction: column !important;
    }
  }

  /* ===================================================
     Upsell placeholder
     =================================================== */
  .rc-upsell-placeholder {
    background-color: #D3D8DD;
    padding: 200px 0;
    text-align: center;
    font-size: 16px;
    line-height: 22px;
    color: #202635;
    font-family: 'FT System', var(--font-body--family), sans-serif;
    font-weight: 400;
  }
</style>

