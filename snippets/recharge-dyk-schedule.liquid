{% comment %}
  Did You Know — Upcoming Orders (Schedule) Tab
  Displays a horizontal image+text educational card matching the Figma
  "Education - image+text" component (740×201).
  Pure markup partial — rendered INSIDE the "schedule.footer" slot template
  in recharge-affinity-homepage.liquid.
  Uses .cf-dyk-schedule BEM prefix to avoid CSS collision with existing
  integration class sets (.cf-did-you-know, .cf-dyk-footer, .cf-articles, .cf-faq).
{% endcomment %}

<style>
  .cf-dyk-schedule {
    margin-top: 32px;
    border-radius: 8px;
    overflow: hidden;
    background-color: #E6F0F8;
    display: flex;
    flex-direction: row;
    align-items: center;
  }

  .cf-dyk-schedule__media {
    width: 358px;
    flex-shrink: 0;
  }

  .cf-dyk-schedule__media img {
    width: 100%;
    height: 201px;
    object-fit: cover;
    display: block;
  }

  .cf-dyk-schedule__text-lockup {
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: space-between;
    padding: 12px 16px 16px 16px;
    flex: 1;
    min-width: 0;
    overflow: hidden;
    align-self: stretch;
  }

  .cf-dyk-schedule__heading {
    display: flex;
    flex-direction: row;
    gap: 8px;
  }

  .cf-dyk-schedule__heading-lockup {
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: flex-end;
    padding-top: 8px;
  }

  .cf-dyk-schedule__eyebrow {
    font-family: 'FT System Mono', monospace;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0.56px;
    text-transform: uppercase;
    color: #202635;
    margin: 0;
  }

  .cf-dyk-schedule__headline {
    font-family: 'FT System', var(--font-heading--family), sans-serif;
    font-weight: 400;
    font-size: 16px;
    line-height: 22px;
    color: #202635;
    margin: 0;
  }

  .cf-dyk-schedule__learn-more {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding-bottom: 4px;
    border-bottom: 1px solid #202635;
    text-decoration: none;
    font-family: 'FT System', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #202635;
    width: fit-content;
  }

  .cf-dyk-schedule__learn-more-arrow {
    font-family: Inter, var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 13px;
    text-align: center;
    color: #202635;
  }
</style>

{%- liquid
  # Hardcoded fallbacks — overridden by the did_you_know_upcoming_orders metaobject when an entry is published.
  assign dyk_eyebrow = 'DID YOU KNOW?'
  assign dyk_heading = 'Tap water can contain contaminants and forever chemicals even when it meets local regulations.'
  assign dyk_link_label = 'Learn more'
  assign dyk_link_url = '#'
  assign dyk_image = nil

  for entry in shop.metaobjects.did_you_know_upcoming_orders.values limit: 1
    assign dyk_eyebrow = entry.eyebrow.value | default: dyk_eyebrow
    assign dyk_heading = entry.heading.value | default: dyk_heading
    assign dyk_link_label = entry.link_label.value | default: dyk_link_label
    assign dyk_link_url = entry.link_url.value | default: dyk_link_url
    assign dyk_image = entry.image.value
  endfor
-%}

<div class="cf-dyk-schedule">
  <div class="cf-dyk-schedule__media">
    {%- if dyk_image != blank -%}
      <img
        src="{{ dyk_image | image_url: width: 716 }}"
        alt="{{ dyk_eyebrow | escape }}"
        width="358"
        height="201"
        loading="lazy"
      >
    {%- else -%}
      <img
        src="{{ 'media-desktop-I1150861211376605.png' | file_url }}"
        alt="Did you know educational content"
        width="358"
        height="201"
        loading="lazy"
      >
    {%- endif -%}
  </div>
  <div class="cf-dyk-schedule__text-lockup">
    <div class="cf-dyk-schedule__heading">
      <div class="cf-dyk-schedule__heading-lockup">
        <p class="cf-dyk-schedule__eyebrow">{{ dyk_eyebrow }}</p>
        <p class="cf-dyk-schedule__headline">{{ dyk_heading | newline_to_br }}</p>
      </div>
    </div>
    <a href="{{ dyk_link_url }}" class="cf-dyk-schedule__learn-more">
      {{ dyk_link_label }}
      <span class="cf-dyk-schedule__learn-more-arrow">&rarr;</span>
    </a>
  </div>
</div>
