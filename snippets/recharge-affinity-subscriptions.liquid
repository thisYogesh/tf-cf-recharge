{% comment %} ===================================================
   JavaScript: Subscriptions page detection + DOM enhancements
   =================================================== {% endcomment %}
<script>
(function() {
  'use strict';

  var SUBS_PATH = '/subscriptions';
  var CLASS_NAME = 'cf-page-subscriptions';
  var isSubsPage = false;
  var rafId = 0;

  /**
   * Check if a pathname matches the subscriptions page
   * @param {string} pathname
   * @returns {boolean}
   */
  function isSubs(pathname) {
    return Boolean(pathname && pathname.indexOf(SUBS_PATH) !== -1);
  }

  /**
   * Activate subscriptions page enhancements
   */
  function activate() {
    if (isSubsPage) {
      scheduleEnhance();
      return;
    }
    isSubsPage = true;
    document.body.classList.add(CLASS_NAME);
    scheduleEnhance();
  }

  /**
   * Deactivate subscriptions page enhancements
   */
  function deactivate() {
    if (!isSubsPage) return;
    isSubsPage = false;
    document.body.classList.remove(CLASS_NAME);
  }

  /**
   * Route check — add or remove subscriptions page class
   * @param {string} pathname
   */
  function checkPage(pathname) {
    if (isSubs(pathname)) {
      activate();
    } else {
      deactivate();
    }
  }

  /**
   * Schedule DOM enhancements via requestAnimationFrame
   */
  function scheduleEnhance() {
    cancelAnimationFrame(rafId);
    rafId = requestAnimationFrame(enhance);
  }

  /**
   * Run all DOM enhancements
   */
  function enhance() {
    if (!isSubsPage) return;
    renameHeading();
    wrapImages();
    addFreqBadges();
    addCountBadges();
  }

  /**
   * Find and rename the native page heading to "Product Subscriptions"
   */
  function renameHeading() {
    /* Already renamed — skip */
    if (document.querySelector('[data-cf-sub-heading]')) return;

    var candidates = document.querySelectorAll(
      '.recharge-heading-h1, .recharge-heading-h2, h1:not(.rc-welcome), h2:not(.rc-welcome)'
    );

    for (var i = 0; i < candidates.length; i++) {
      var el = candidates[i];
      /* Skip welcome heading and our own education card headings */
      if (el.id === 'rc-welcome-heading') continue;
      if (el.classList.contains('rc-welcome')) continue;
      if (el.closest('.cf-edu-card')) continue;
      if (el.closest('[data-cf-overview]')) continue;

      var text = el.textContent.trim().toLowerCase();
      if (text.indexOf('subscription') !== -1) {
        el.textContent = 'Product Subscriptions';
        el.setAttribute('data-cf-sub-heading', '');
        return;
      }
    }
  }

  /**
   * Wrap .recharge-image elements in .cf-sub-img-wrap containers
   * for the rotated-background pseudo-element treatment
   */
  function wrapImages() {
    if (!isSubsPage) return;

    var images = document.querySelectorAll('.recharge-image');
    for (var i = 0; i < images.length; i++) {
      var img = images[i];
      /* Already wrapped — skip */
      if (img.closest('.cf-sub-img-wrap')) continue;
      /* Skip homepage overview card images */
      if (img.closest('[data-cf-overview]')) continue;
      /* Skip education card images */
      if (img.closest('.cf-edu-card')) continue;

      var parent = img.parentElement;
      if (!parent) continue;

      var wrap = document.createElement('div');
      wrap.className = 'cf-sub-img-wrap';
      parent.insertBefore(wrap, img);
      wrap.appendChild(img);
    }
  }

  /**
   * Find frequency text elements (e.g. "Every 2 months")
   * and add .cf-freq-badge class for pill styling
   */
  function addFreqBadges() {
    if (!isSubsPage) return;

    var freqRe = /^every\s+\d+\s+(month|week|day|year)s?$/i;
    var candidates = document.querySelectorAll(
      '.recharge-text, .recharge-text-p1, .recharge-text-p2, .recharge-text-p3, ' +
      '.recharge-text-p4, .recharge-text-p5, span, small, p, div'
    );

    for (var i = 0; i < candidates.length; i++) {
      var el = candidates[i];
      /* Already badged — skip */
      if (el.classList.contains('cf-freq-badge')) continue;
      /* Only leaf nodes (no children elements) */
      if (el.children.length > 0) continue;
      /* Skip elements outside subscription cards */
      if (el.closest('.cf-edu-card')) continue;

      var t = el.textContent.trim();
      if (freqRe.test(t)) {
        el.classList.add('cf-freq-badge');
      }
    }
  }

  /**
   * Tag the quantity count badges (the dark circular "1" / "5" indicators
   * on item images and the "Bundle contents (N)" header) with
   * .cf-count-badge so CSS can recolor them. A count badge is detected as a
   * leaf element inside a subscription item whose entire text is an integer.
   * The badge "root" (the circle) may be an ancestor of the number text, so
   * we walk up while the ancestor's only content is still that number.
   */
  function addCountBadges() {
    if (!isSubsPage) return;

    var items = document.querySelectorAll('.recharge-component-subscription-item');
    for (var i = 0; i < items.length; i++) {
      var item = items[i];
      var els = item.querySelectorAll('span, div, p, small, b, strong');
      for (var j = 0; j < els.length; j++) {
        var el = els[j];
        if (el.children.length > 0) continue;          /* leaf only */
        if (el.classList.contains('cf-count-badge')) continue;
        if (el.classList.contains('cf-freq-badge')) continue;

        var t = el.textContent.trim();
        if (!/^\d+$/.test(t)) continue;

        /* Walk up to the badge container (the circle), staying within the
           item and only while the ancestor wraps just this number. */
        var root = el;
        while (root.parentElement &&
               root.parentElement !== item &&
               root.parentElement.children.length <= 1 &&
               root.parentElement.textContent.trim() === t) {
          root = root.parentElement;
        }
        root.classList.add('cf-count-badge');
      }
    }
  }

  /* -------------------------------------------------
     Event Listeners
     ------------------------------------------------- */

  /* Recharge SPA route change */
  document.addEventListener('Recharge::location::change', function(event) {
    var pathname = (event.detail && event.detail.pathname) || '';
    checkPage(pathname);
  });

  /* Slot mount — backup detection */
  document.addEventListener('Recharge::slot::mounted', function(event) {
    var pathname = (event.detail && event.detail.pathname) || '';
    if (isSubs(pathname)) {
      activate();
    }
  });

  /* MutationObserver for dynamically rendered content */
  var observer = new MutationObserver(function(mutations) {
    if (!isSubsPage) return;
    var hasNew = false;
    for (var i = 0; i < mutations.length; i++) {
      if (mutations[i].addedNodes.length > 0) {
        hasNew = true;
        break;
      }
    }
    if (hasNew) scheduleEnhance();
  });

  observer.observe(document.body || document.documentElement, {
    childList: true,
    subtree: true
  });

  /* Initial check with delay for SPA routing */
  setTimeout(function() {
    var path = window.location.pathname + window.location.hash;
    checkPage(path);
  }, 500);
})();
</script>
