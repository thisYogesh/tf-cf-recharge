  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) a:hover,
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) button:hover,
