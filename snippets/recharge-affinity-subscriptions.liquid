{% comment %}
  Recharge Affinity Customer Portal — Subscriptions Page Reskin
  ==============================================================
  Restyling the /subscriptions page to match the Figma design:
  - Custom heading ("Product Subscriptions")
  - Bottom-border status tabs (Active/Inactive) instead of pill tabs
  - Styled subscription cards with rotated-background product images
  - Frequency badge pills
  - Education Zone card injected via subscriptions.footer slot

  Strategy:
  - JS IIFE detects the subscriptions page via Recharge::location::change event,
    adds/removes body.cf-page-subscriptions class for CSS scoping.
  - MutationObserver wraps .recharge-image elements in .cf-sub-img-wrap for
    the rotated-background pseudo-element treatment.
  - MutationObserver finds frequency text and adds .cf-freq-badge class.
  - CSS overrides scoped under body.cf-page-subscriptions to avoid affecting
    other portal pages (overview, schedule, etc.).
  - Education Zone card injected via subscriptions.footer slot with two
    responsive variants (desktop/mobile) toggled by CSS media queries.
{% endcomment %}

<style>
  /* ===================================================
     Subscriptions Page — Hide Welcome Heading
     =================================================== */
  body.cf-page-subscriptions .rc-welcome,
  body.cf-page-subscriptions .rc-header-slot {
    display: none !important;
  }

  /* ===================================================
     Subscriptions Page — Page Heading
     =================================================== */
  body.cf-page-subscriptions [data-cf-sub-heading] {
    font-size: 42px !important;
    line-height: 55px !important;
    letter-spacing: -0.84px !important;
    color: #202635 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-heading--family), sans-serif !important;
    margin: 0 !important;
    padding-bottom: 4px !important;
  }

  /* ===================================================
     Subscriptions Page — Active/Inactive status tabs (bottom-border style)
     ----------------------------------------------------
     IMPORTANT: This must ONLY restyle the in-content "Active / Inactive"
     status filter — NOT the persistent top portal navigation
     (Dashboard / My Products / Upcoming orders / …). The top nav is a
     [role="tablist"] whose tabs carry data-testid="portal-nav-item-*" and
     class "recharge-tab-navigation-item"; those pills must keep the global
     pill style so the navigation looks identical across all routes
     (matching /overview). We therefore exclude the navigation tablist/tabs
     from every selector below.
     =================================================== */
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) {
    gap: 24px !important;
    padding-bottom: 0 !important;
  }

  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) [role="tab"],
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) a,
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) button,
  body.cf-page-subscriptions .recharge-tab:not(.recharge-tab-navigation-item),
  body.cf-page-subscriptions .recharge-tab-active:not(.recharge-tab-navigation-item),
  body.cf-page-subscriptions .recharge-tab-inactive:not(.recharge-tab-navigation-item) {
    border-radius: 0 !important;
    border: none !important;
    border-bottom: 1px solid #797D86 !important;
    background-color: transparent !important;
    padding: 8px 0 !important;
    color: #797D86 !important;
    font-size: 16px !important;
    line-height: 23px !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    font-weight: 400 !important;
    white-space: nowrap !important;
  }

  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) [role="tab"][aria-selected="true"],
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) a[aria-selected="true"],
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) a[aria-current],
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) a.active,
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) button[aria-selected="true"],
  body.cf-page-subscriptions .recharge-theme [role="tablist"]:not(:has([data-testid^="portal-nav-item"])):not(:has(.recharge-tab-navigation-item)) button.active,
  body.cf-page-subscriptions .recharge-tab-active:not(.recharge-tab-navigation-item) {
    border-bottom-color: #2C70BB !important;
    color: #202635 !important;
    background-color: transparent !important;
  }

