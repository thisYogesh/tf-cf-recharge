      line-height: 20px !important;
    }
    .cf-order-summary__promo-input {
      font-size: 10px !important;
      line-height: 15px !important;
      letter-spacing: 0.1px !important;
    }
  }
</style>

{% comment %} SLOT: overview.footer — Order Summary Card {% endcomment %}
<script type="text/html" data-recharge-slot="overview.footer">
  <div class="cf-order-summary" id="cf-order-summary-card">
    <!-- In your order -->
    <h3 class="cf-order-summary__heading">In your order</h3>
    <div class="cf-order-summary__products" data-cf-os-products>
      <div class="cf-order-summary__loading">Loading order details...</div>
    </div>

    <!-- Order Summary -->
    <h3 class="cf-order-summary__heading">Order Summary</h3>
    <div class="cf-order-summary__summary" data-cf-os-summary>
      <div class="cf-order-summary__financials" data-cf-os-financials>
        <div class="cf-order-summary__loading">Loading...</div>
      </div>
      <div class="cf-order-summary__promo" data-cf-os-promo>
        <input type="text" class="cf-order-summary__promo-input" placeholder="Enter promo code" data-cf-os-promo-input />
        <button type="button" class="cf-order-summary__promo-btn" data-cf-os-promo-btn>Apply</button>
      </div>
    </div>

    <!-- Delivery Address & Payment -->
    <h3 class="cf-order-summary__heading">Delivery Address &amp; Payment</h3>
    <div class="cf-order-summary__delivery" data-cf-os-delivery>
      <div class="cf-order-summary__loading">Loading...</div>
    </div>
  </div>
</script>

<script>
(function() {
  'use strict';

  /* ── Inline SVG: Info icon (13x13 circle with 'i') ── */
  var SVG_INFO = '<svg width="13" height="13" viewBox="0 0 13 13" fill="none" xmlns="http://www.w3.org/2000/svg">' +
    '<circle cx="6.5" cy="6.5" r="6" stroke="#2C70BB" stroke-width="1" fill="#FFFFFF"/>' +
    '<text x="6.5" y="10" text-anchor="middle" font-family="FT System, system-ui, sans-serif" font-size="10.4" font-weight="400" letter-spacing="-0.1" fill="#2C70BB">i</text>' +
    '</svg>';

  /* ── State ── */
  var _initialized = false;
  var _session = null;
  var _subscriptions = [];

  /* ── Helpers ── */
  function formatPrice(cents) {
    if (typeof cents === 'string') {
      var num = parseFloat(cents);
      if (isNaN(num)) return cents;
      return '$' + num.toFixed(2) + ' USD';
    }
    if (typeof cents === 'number') {
      return '$' + cents.toFixed(2) + ' USD';
    }
    return '$0.00 USD';
  }

  function getCard() {
    return document.getElementById('cf-order-summary-card');
  }

  /* ── Product image fetcher via Shopify AJAX API ── */
  function fetchProductImage(handle) {
    if (!handle) return Promise.resolve(null);
    var url = '/products/' + encodeURIComponent(handle) + '.json';
    return fetch(url)
      .then(function(res) {
        if (!res.ok) return null;
        return res.json();
      })
      .then(function(data) {
        if (!data || !data.product) return null;
        var images = data.product.images;
        if (images && images.length > 0) return images[0].src;
        return null;
      })
      .catch(function() { return null; });
  }

  /* ── Build a product handle from title ── */
  function titleToHandle(title) {
    if (!title) return '';
    return title
      .toLowerCase()
      .replace(/[^a-z0-9]+/g, '-')
      .replace(/^-+|-+$/g, '');
  }

  /* ── Render product items ── */
  function renderProducts(container, subscriptions, imageMap) {
    container.innerHTML = '';
    if (!subscriptions.length) {
      container.innerHTML = '<div class="cf-order-summary__loading">No items found.</div>';
      return;
    }

    subscriptions.forEach(function(sub) {
      var title = sub.product_title || 'Product';
      var price = sub.price ? parseFloat(sub.price) : 0;
      var qty = sub.quantity || 1;
      var priceStr = price.toFixed(2) + ' USD';
      var imgSrc = imageMap[sub.id] || '';

      var row = document.createElement('div');
      row.className = 'cf-order-summary__product';

      var imgWrap = document.createElement('div');
      imgWrap.className = 'cf-order-summary__img-wrap';

      if (imgSrc) {
        var img = document.createElement('img');
        img.className = 'cf-order-summary__img';
        img.src = imgSrc;
        img.alt = title;
        img.loading = 'lazy';
        imgWrap.appendChild(img);
      }

      var qtyBadge = document.createElement('span');
      qtyBadge.className = 'cf-order-summary__qty';
      qtyBadge.textContent = String(qty);
      imgWrap.appendChild(qtyBadge);

      var info = document.createElement('div');
      info.className = 'cf-order-summary__product-info';

      var meta = document.createElement('div');
      meta.className = 'cf-order-summary__product-meta';

      var titleEl = document.createElement('p');
      titleEl.className = 'cf-order-summary__product-title';
      titleEl.textContent = title;

      var priceEl = document.createElement('p');
      priceEl.className = 'cf-order-summary__product-price';
      priceEl.textContent = priceStr;

      meta.appendChild(titleEl);
      meta.appendChild(priceEl);

      var editBtn = document.createElement('button');
      editBtn.type = 'button';
      editBtn.className = 'cf-order-summary__edit-btn';
      editBtn.textContent = 'Edit';
      editBtn.addEventListener('click', function() {
        /* Navigate to subscription management for this subscription */
        var subId = sub.id;
        document.dispatchEvent(new CustomEvent('Recharge::click::manageSubscription', {
          detail: { subscriptionIds: [subId] }
        }));
        /* Fallback: navigate to subscriptions page */
        window.location.href = '/tools/recurring/subscriptions';
      });

      info.appendChild(meta);
      info.appendChild(editBtn);

      row.appendChild(imgWrap);
      row.appendChild(info);
      container.appendChild(row);
    });
  }

  /* ── Render financial summary ── */
  function renderFinancials(container, subscriptions) {
    container.innerHTML = '';

    var subtotal = 0;
    subscriptions.forEach(function(sub) {
      var price = sub.price ? parseFloat(sub.price) : 0;
      var qty = sub.quantity || 1;
      subtotal += price * qty;
    });

    var rows = [
      { label: 'Subtotal', value: formatPrice(subtotal), info: false },
      { label: 'Taxes', value: '$0.00 USD', info: true },
      { label: 'Shipping:', value: 'FREE', info: false },
    ];

    rows.forEach(function(r) {
      var row = document.createElement('div');
      row.className = 'cf-order-summary__row';

      var labelSpan = document.createElement('span');
      labelSpan.className = 'cf-order-summary__row-label';
      if (r.info) {
        var icon = document.createElement('span');
        icon.className = 'cf-order-summary__info-icon';
        icon.innerHTML = SVG_INFO;
        labelSpan.appendChild(icon);
      }
      var labelText = document.createTextNode(r.label);
      labelSpan.appendChild(labelText);

      var valueSpan = document.createElement('span');
      valueSpan.className = 'cf-order-summary__row-value';
      valueSpan.textContent = r.value;

      row.appendChild(labelSpan);
      row.appendChild(valueSpan);
      container.appendChild(row);
    });

    /* Order Total row */
    var totalRow = document.createElement('div');
    totalRow.className = 'cf-order-summary__row cf-order-summary__row--total';

    var totalLabel = document.createElement('span');
    totalLabel.className = 'cf-order-summary__row-label';
    var totalIcon = document.createElement('span');
    totalIcon.className = 'cf-order-summary__info-icon';
    totalIcon.innerHTML = SVG_INFO;
    totalLabel.appendChild(totalIcon);
    var totalText = document.createTextNode('Order Total');
    totalLabel.appendChild(totalText);

    var totalValue = document.createElement('span');
    totalValue.className = 'cf-order-summary__row-value';
    totalValue.textContent = formatPrice(subtotal);

    totalRow.appendChild(totalLabel);
    totalRow.appendChild(totalValue);
    container.appendChild(totalRow);
  }

  /* ── Render delivery & payment section ── */
  function renderDelivery(container, addressLine, paymentLine) {
    container.innerHTML = '';

    /* Address row */
    var addrRow = document.createElement('div');
    addrRow.className = 'cf-order-summary__delivery-row';
    var addrText = document.createElement('span');
    addrText.textContent = addressLine || '---';
    var addrLink = document.createElement('a');
    addrLink.className = 'cf-order-summary__edit-link';
    addrLink.textContent = 'Edit Address';
    addrLink.href = '/tools/recurring/shipping';
    addrRow.appendChild(addrText);
    addrRow.appendChild(addrLink);

    /* Payment row */
    var payRow = document.createElement('div');
    payRow.className = 'cf-order-summary__delivery-row';
    var payText = document.createElement('span');
    payText.textContent = paymentLine || '---';
    var payLink = document.createElement('a');
    payLink.className = 'cf-order-summary__edit-link';
    payLink.textContent = 'Edit Payment';
    payLink.href = '/tools/recurring/payment_methods';
    payRow.appendChild(payText);
    payRow.appendChild(payLink);

    container.appendChild(addrRow);
    container.appendChild(payRow);
  }

  /* ── Format address line from address object ── */
  function formatAddressLine(addr) {
    if (!addr) return '---';
    var parts = [];
    if (addr.address1) parts.push(addr.address1);
    else if (addr.street) parts.push(addr.street);
    if (parts.length) return parts.join(', ');
    /* Fallback: city + province */
    var loc = [];
    if (addr.city) loc.push(addr.city);
    if (addr.province) loc.push(addr.province);
    if (loc.length) return loc.join(', ');
    return '---';
  }

  /* ── Format payment method line ── */
  function formatPaymentLine(pm) {
    if (!pm) return '---';
    var brand = pm.payment_details && pm.payment_details.brand
      ? pm.payment_details.brand
      : (pm.brand || '');
    var last4 = pm.payment_details && pm.payment_details.last4
      ? pm.payment_details.last4
      : (pm.last4 || pm.last_four || '');
    if (brand && last4) {
      return brand.charAt(0).toUpperCase() + brand.slice(1) + ' ending in ' + last4;
    }
    if (pm.payment_type) return pm.payment_type;
    return '---';
  }

  /* ── Main init: fetch data and render ── */
  function initOrderSummary() {
    if (typeof recharge === 'undefined' || !recharge.auth) return;

    var card = getCard();
    if (!card) return;

    var authPromise;
    if (_session) {
      authPromise = Promise.resolve(_session);
    } else {
      authPromise = recharge.auth.loginCustomerPortal()
        .then(function(s) { _session = s; return s; });
    }

    authPromise.then(function(session) {
      /* Fetch subscriptions */
      return recharge.subscription.listSubscriptions(session, {
        limit: 25,
        sort_by: 'id-asc',
        status: 'Active'
      }).then(function(res) {
        _subscriptions = res.subscriptions || [];
        return _subscriptions;
      });
    }).then(function(subs) {
      if (!subs.length) {
        var productsContainer = card.querySelector('[data-cf-os-products]');
        if (productsContainer) productsContainer.innerHTML = '<div class="cf-order-summary__loading">No active subscriptions.</div>';
        return;
      }

      /* Fetch product images in parallel */
      var imagePromises = subs.map(function(sub) {
        var handle = sub.shopify_product_handle || sub.product_handle || titleToHandle(sub.product_title);
        return fetchProductImage(handle).then(function(src) {
          return { id: sub.id, src: src };
        });
      });

      /* Fetch addresses */
      var addressPromise;
      if (recharge.address && recharge.address.listAddresses) {
        addressPromise = recharge.address.listAddresses(_session, { limit: 1 })
          .then(function(res) { return (res.addresses && res.addresses[0]) || null; })
          .catch(function() { return null; });
      } else {
        /* Fallback: try to get address from first subscription */
        var firstSub = subs[0];
        addressPromise = Promise.resolve(
          firstSub.address_id ? { address1: firstSub.address1 || '' } : null
        );
      }

      /* Fetch payment methods */
      var paymentPromise;
      if (recharge.paymentMethod && recharge.paymentMethod.listPaymentMethods) {
        paymentPromise = recharge.paymentMethod.listPaymentMethods(_session, { limit: 1 })
          .then(function(res) { return (res.payment_methods && res.payment_methods[0]) || null; })
          .catch(function() { return null; });
      } else {
        paymentPromise = Promise.resolve(null);
      }

      return Promise.all([
        Promise.all(imagePromises),
        addressPromise,
        paymentPromise
      ]).then(function(results) {
        var imageResults = results[0];
        var address = results[1];
        var payment = results[2];

        /* Build image map */
        var imageMap = {};
        imageResults.forEach(function(r) {
          if (r.src) imageMap[r.id] = r.src;
        });

        /* Render products */
        var productsContainer = card.querySelector('[data-cf-os-products]');
        if (productsContainer) renderProducts(productsContainer, subs, imageMap);

        /* Render financials */
        var financialsContainer = card.querySelector('[data-cf-os-financials]');
        if (financialsContainer) renderFinancials(financialsContainer, subs);

        /* Render delivery & payment */
        var deliveryContainer = card.querySelector('[data-cf-os-delivery]');
        if (deliveryContainer) {
          var addressLine = formatAddressLine(address);
          var paymentLine = formatPaymentLine(payment);
          renderDelivery(deliveryContainer, addressLine, paymentLine);
        }
      });
    }).catch(function(err) {
      console.error('[CF Order Summary] Init failed:', err);
    });
  }

  /* ── Lifecycle events ── */
  document.addEventListener('Recharge::slot::mounted', function(event) {
    var name = event.detail && event.detail.name;
    if (name === 'footer') {
      initOrderSummary();
    }
  });

  document.addEventListener('Recharge::action::orderChanged', function() {
    _subscriptions = [];
    initOrderSummary();
  });

  /* ── Promo code button handler (delegated) ── */
  document.addEventListener('click', function(e) {
    if (!e.target || !e.target.hasAttribute('data-cf-os-promo-btn')) return;
    var card = getCard();
    if (!card) return;
    var input = card.querySelector('[data-cf-os-promo-input]');
    if (!input) return;
    var code = input.value.trim();
    if (!code) return;
    /* Store promo code — the Recharge portal does not expose a promo API
       via the storefront SDK, so we store it for reference. A full
       implementation would call the Recharge discount/charge endpoint. */
    console.log('[CF Order Summary] Promo code entered:', code);
    e.target.textContent = 'Applied';
    e.target.disabled = true;
    setTimeout(function() {
      e.target.textContent = 'Apply';
      e.target.disabled = false;
    }, 3000);
  });

  /* ── MutationObserver fallback for slot detection ── */
  var _observerStarted = false;
  function startObserver() {
    if (_observerStarted) return;
    _observerStarted = true;
    var observer = new MutationObserver(function() {
      var card = getCard();
      if (card && !card.hasAttribute('data-cf-os-initialized')) {
        card.setAttribute('data-cf-os-initialized', 'true');
        initOrderSummary();
      }
    });
    observer.observe(document.body || document.documentElement, {
      childList: true,
      subtree: true
    });
  }

  /* ── Retry init if Recharge SDK not yet loaded ── */
  var _retries = 0;
  function retryInit() {
    if (++_retries > 30) return;
    if (typeof recharge !== 'undefined' && recharge.auth) {
      startObserver();
      /* Try immediate init if card already in DOM */
      var card = getCard();
      if (card && !card.hasAttribute('data-cf-os-initialized')) {
        card.setAttribute('data-cf-os-initialized', 'true');
        initOrderSummary();
      }
      return;
    }
    setTimeout(retryInit, 1000);
  }
  setTimeout(retryInit, 500);
})();
</script>
