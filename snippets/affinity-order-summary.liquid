  /* ===================================================
     Pricing section — "Order Summary"
     =================================================== */
  .cf-order-summary__pricing {
    display: flex !important;
    flex-direction: column !important;
    gap: 8px !important;
    align-items: center !important;
  }
  .cf-order-summary__pricing-rows {
    display: flex !important;
    flex-direction: column !important;
    gap: 4px !important;
    width: 100% !important;
  }
  .cf-order-summary__pricing-row {
    display: flex !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    width: 100% !important;
  }
  .cf-order-summary__pricing-label {
    display: flex !important;
    align-items: center !important;
    gap: 4px !important;
    font-size: 16px !important;
    line-height: 22px !important;
    color: #202635 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
