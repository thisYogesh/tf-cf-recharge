{% comment %}
  Order Summary Card — Recharge Affinity Portal (overview.footer slot)
  ====================================================================
  Renders the "In your order" / "Order Summary" / "Delivery Address & Payment"
  card on the Affinity overview page. Populates via Recharge Storefront SDK
  (subscriptions, addresses, payment methods) and Shopify AJAX product API
  (product images).

  Injection: data-recharge-slot="overview.footer"
  Lifecycle: Recharge::slot::mounted → init, Recharge::action::orderChanged → re-fetch
{% endcomment %}

<style>
  /* ===================================================
     Hide the existing upsell placeholder from
     recharge-affinity-homepage.liquid so it doesn't
     appear above the order summary card.
     =================================================== */
  .rc-upsell-placeholder {
    display: none !important;
  }

  /* ===================================================
     Order Summary Card — .cf-order-summary BEM block
     =================================================== */
  .cf-order-summary {
    border: 1px solid #D9E8F4 !important;
    background: #FFFFFF !important;
    padding: 0 18px 20px 18px !important;
    display: flex !important;
    flex-direction: column !important;
    gap: 20px !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    box-sizing: border-box !important;
    width: 100% !important;
  }

  /* --- Section headings --- */
  .cf-order-summary__heading {
    font-family: 'FT System', var(--font-heading--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 20px !important;
    line-height: 26px !important;
    letter-spacing: -0.2px !important;
    color: #202635 !important;
    margin: 0 !important;
    padding: 0 !important;
  }

  /* --- Product row --- */
  .cf-order-summary__product {
    display: flex !important;
    flex-direction: row !important;
    gap: 20px !important;
    align-items: center !important;
  }

  /* Product image container with tilted background rects */
  .cf-order-summary__img-wrap {
    position: relative !important;
    width: 92px !important;
    height: 92px !important;
    flex-shrink: 0 !important;
  }
  .cf-order-summary__img-wrap::before {
    content: '' !important;
    position: absolute !important;
    top: 0 !important;
    left: 0 !important;
    width: 100% !important;
    height: 100% !important;
    background: #F2F7FB !important;
    transform: rotate(3.1deg) !important;
    border-radius: 2px !important;
  }
  .cf-order-summary__img-wrap::after {
    content: '' !important;
    position: absolute !important;
    top: 0 !important;
    left: 5px !important;
    width: 89% !important;
    height: 100% !important;
    background: #ECF7FF !important;
    opacity: 0.15 !important;
    transform: rotate(3.1deg) !important;
    border-radius: 2px !important;
  }

  /* Product image */
  .cf-order-summary__img {
    position: absolute !important;
    top: 50% !important;
    left: 50% !important;
    transform: translate(-50%, -50%) !important;
    max-width: 50px !important;
    max-height: 55px !important;
    object-fit: contain !important;
    z-index: 1 !important;
  }

  /* Quantity badge */
  .cf-order-summary__qty {
    position: absolute !important;
    bottom: 0 !important;
    left: 0 !important;
    width: 23px !important;
    height: 23px !important;
    background: #202635 !important;
    border-radius: 63px !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    z-index: 2 !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 15px !important;
    line-height: 21px !important;
    letter-spacing: 0.6px !important;
    text-transform: uppercase !important;
    color: #FFFFFF !important;
  }

  /* Product info column */
  .cf-order-summary__product-info {
    display: flex !important;
    flex-direction: column !important;
    gap: 8px !important;
    min-width: 0 !important;
  }
  .cf-order-summary__product-meta {
    display: flex !important;
    flex-direction: column !important;
    gap: 0 !important;
  }
  .cf-order-summary__product-title {
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 18px !important;
    line-height: 25px !important;
    color: #24293B !important;
    margin: 0 !important;
  }
  .cf-order-summary__product-price {
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 16px !important;
    line-height: 22px !important;
    color: #202635 !important;
    margin: 0 !important;
  }

  /* Edit button (pill) */
  .cf-order-summary__edit-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    background: #FFFFFF !important;
    color: #202635 !important;
    border: 1px solid #202635 !important;
    border-radius: 42px !important;
    padding: 6px 20px 8px !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 14px !important;
    line-height: 20px !important;
    text-align: center !important;
    cursor: pointer !important;
    white-space: nowrap !important;
  }
  .cf-order-summary__edit-btn:hover {
    background: #f0f4f8 !important;
  }

  /* --- Financial summary --- */
  .cf-order-summary__financials {
    display: flex !important;
    flex-direction: column !important;
    gap: 4px !important;
    width: 100% !important;
  }
  .cf-order-summary__row {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    width: 100% !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 16px !important;
    line-height: 22px !important;
    color: #202635 !important;
  }
  .cf-order-summary__row-label {
    display: flex !important;
    align-items: center !important;
    gap: 4px !important;
  }
  .cf-order-summary__row-value {
    text-align: right !important;
  }
  .cf-order-summary__row--total {
    font-size: 18px !important;
    line-height: 25px !important;
  }
  .cf-order-summary__row--total .cf-order-summary__row-value {
    font-size: 18px !important;
    line-height: 25px !important;
  }

  /* Info icon (circle with 'i') */
  .cf-order-summary__info-icon {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 13px !important;
    height: 13px !important;
    flex-shrink: 0 !important;
  }
  .cf-order-summary__info-icon svg {
    width: 13px !important;
    height: 13px !important;
  }

  /* --- Promo code section --- */
  .cf-order-summary__promo {
    display: flex !important;
    flex-direction: row !important;
    gap: 14px !important;
    align-items: center !important;
    width: 100% !important;
  }
  .cf-order-summary__promo-input {
    flex: 1 !important;
    height: 34px !important;
    border: 1px solid #D3D8DD !important;
    border-radius: 6px !important;
    padding: 0 12px !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 14px !important;
    line-height: 21px !important;
    color: #202635 !important;
    background: #FFFFFF !important;
    outline: none !important;
    box-sizing: border-box !important;
  }
  .cf-order-summary__promo-input::placeholder {
    color: #202635 !important;
    opacity: 0.5 !important;
  }
  .cf-order-summary__promo-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    gap: 10px !important;
    background: #FFFFFF !important;
    color: #202635 !important;
    border: 1px solid #202635 !important;
    border-radius: 42px !important;
    padding: 6px 20px 8px !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 14px !important;
    line-height: 20px !important;
    text-align: center !important;
    cursor: pointer !important;
    white-space: nowrap !important;
    flex-shrink: 0 !important;
  }
  .cf-order-summary__promo-btn:hover {
    background: #f0f4f8 !important;
  }

  /* --- Delivery / Payment section --- */
  .cf-order-summary__delivery {
    display: flex !important;
    flex-direction: column !important;
    gap: 0 !important;
    width: 100% !important;
  }
  .cf-order-summary__delivery-row {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    width: 100% !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 16px !important;
    line-height: 22px !important;
    letter-spacing: -0.16px !important;
    color: #202635 !important;
  }
  .cf-order-summary__edit-link {
    text-decoration: underline !important;
    color: #2C70BB !important;
    font-family: 'FT System', var(--font-body--family, system-ui), sans-serif !important;
    font-weight: 400 !important;
    font-size: 16px !important;
    line-height: 23px !important;
    cursor: pointer !important;
    background: none !important;
    border: none !important;
    padding: 0 !important;
  }
  .cf-order-summary__edit-link:hover {
    opacity: 0.8 !important;
  }

  /* --- Products list container --- */
  .cf-order-summary__products {
    display: flex !important;
    flex-direction: column !important;
    gap: 8px !important;
    width: 100% !important;
  }

  /* --- Summary section container (financials + promo) --- */
  .cf-order-summary__summary {
    display: flex !important;
    flex-direction: column !important;
    gap: 8px !important;
    align-items: center !important;
    width: 100% !important;
  }

  /* --- Loading / Empty state --- */
  .cf-order-summary__loading {
    text-align: center !important;
    padding: 20px 0 !important;
    font-size: 14px !important;
    line-height: 20px !important;
    color: #797D86 !important;
  }

  /* ===================================================
     Responsive — Mobile (max-width: 767px)
     =================================================== */
  @media screen and (max-width: 767px) {
    .cf-order-summary__heading {
      font-size: 16px !important;
      line-height: 21px !important;
      letter-spacing: -0.16px !important;
    }
    .cf-order-summary__img-wrap {
      width: 80px !important;
      height: 80px !important;
    }
    .cf-order-summary__img {
      max-width: 40px !important;
