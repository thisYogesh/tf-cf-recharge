    border-color: #2C70BB !important;
  }
  .cf-order-summary__apply-btn {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 78px !important;
    height: 34px !important;
    border-radius: 42px !important;
    border: 1px solid #202635 !important;
    background: #FFFFFF !important;
    color: #202635 !important;
    font-size: 14px !important;
    line-height: 20px !important;
    text-align: center !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    font-weight: 400 !important;
    cursor: pointer !important;
    padding: 6px 20px 8px 20px !important;
    box-sizing: border-box !important;
    flex-shrink: 0 !important;
  }
  .cf-order-summary__apply-btn:hover {
    background: #f0f4f8 !important;
  }

  /* ===================================================
     Delivery Address & Payment section
     =================================================== */
  .cf-order-summary__delivery {
    display: flex !important;
    flex-direction: column !important;
    gap: 0 !important;
  }
  .cf-order-summary__delivery-row {
    display: flex !important;
    flex-direction: row !important;
    justify-content: space-between !important;
    align-items: center !important;
    width: 100% !important;
  }
  .cf-order-summary__delivery-text {
    font-size: 16px !important;
    line-height: 22px !important;
    letter-spacing: -0.16px !important;
    color: #202635 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    margin: 0 !important;
  }
  .cf-order-summary__edit-link {
    font-size: 16px !important;
    line-height: 23px !important;
    color: #2C70BB !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    text-decoration: underline !important;
    cursor: pointer !important;
