      line-height: 20px !important;
      letter-spacing: -0.14px !important;
    }
    .cf-order-summary__row--total .cf-order-summary__row-value {
      font-size: 14px !important;
      line-height: 20px !important;
      letter-spacing: -0.14px !important;
    }
    .cf-order-summary__delivery-row {
      font-size: 14px !important;
      line-height: 20px !important;
      letter-spacing: -0.14px !important;
    }
    .cf-order-summary__edit-link {
