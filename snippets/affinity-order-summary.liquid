    line-height: 22px !important;
    color: #202635 !important;
    font-weight: 400 !important;
    font-family: 'FT System', var(--font-body--family), sans-serif !important;
    text-align: right !important;
    margin: 0 !important;
  }

  /* Order Total — larger font */
  .cf-order-summary__pricing-row--total .cf-order-summary__pricing-label {
    font-size: 18px !important;
    line-height: 25px !important;
  }
  .cf-order-summary__pricing-row--total .cf-order-summary__pricing-value {
    font-size: 18px !important;
    line-height: 25px !important;
  }

  /* Info icon circle */
  .cf-order-summary__info-icon {
    display: inline-flex !important;
    align-items: center !important;
    justify-content: center !important;
    width: 13px !important;
    height: 13px !important;
    flex-shrink: 0 !important;
    color: #2C70BB !important;
    cursor: help !important;
  }
  .cf-order-summary__info-icon svg {
    width: 13px !important;
    height: 13px !important;
