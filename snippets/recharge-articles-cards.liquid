{% comment %}
  Articles Cards — Recharge Affinity Integration
  Displays a horizontally-scrollable row of blog article cards with image,
  eyebrow, headline, and learn-more link. Matches Figma "Articles Cards" design.
  Pure markup partial — rendered INSIDE the "subscriptions.footer" slot template
  in recharge-affinity-homepage.liquid, below the Did You Know footer card.
  Uses .cf-articles BEM prefix to avoid CSS collision with existing
  .cf-did-you-know and .cf-dyk-footer selectors.

  Content is sourced from the "articles_recharge" metaobject (display name
  "Articles - Recharge"), one entry per card, rendered in creation order (limit 3).
  Fields: image, eyebrow, headline, link_url, link_label.
  If no entries are published, the for-loop {% raw %}{% else %}{% endraw %} block
  renders the hardcoded fallback cards so the section always displays.

  NOTE: shop.metaobjects.<type>.values is a lazy drop — iterate it directly;
  .first / [0] return blank. The {% raw %}{% else %}{% endraw %} clause fires when no
  entries exist.
{% endcomment %}

<style>
  .cf-articles {
    margin-top: 32px;
  }

  .cf-articles__scroll {
    overflow-x: auto;
    scrollbar-width: none;
  }

  .cf-articles__scroll::-webkit-scrollbar {
    display: none;
  }

  .cf-articles__container {
    display: flex;
    flex-direction: row;
    gap: 10px;
    align-items: center;
  }

  .cf-articles__card {
    width: 312px;
    flex-shrink: 0;
    border-radius: 8px;
    overflow: hidden;
    background-color: #E6F0F8;
    display: flex;
    flex-direction: column;
  }

  .cf-articles__media {
    overflow: hidden;
  }

  .cf-articles__media img {
    width: 100%;
    height: 175px;
    object-fit: cover;
    display: block;
  }

  .cf-articles__text-lockup {
    padding: 12px 16px 16px 16px;
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: space-between;
    flex: 1;
    overflow: hidden;
  }

  .cf-articles__heading {
    display: flex;
    flex-direction: row;
    gap: 8px;
  }

  .cf-articles__heading-lockup {
    display: flex;
    flex-direction: column;
    gap: 8px;
    justify-content: flex-end;
    padding-top: 8px;
  }

  .cf-articles__eyebrow {
    font-family: 'FT System Mono', monospace;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    letter-spacing: 0.56px;
    text-transform: uppercase;
    color: #202635;
    margin: 0;
  }

  .cf-articles__headline {
    font-family: 'FT System', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 18px;
    line-height: 25px;
    color: #202635;
    margin: 0;
  }

  .cf-articles__learn-more {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    padding-bottom: 4px;
    border-bottom: 1px solid #202635;
    text-decoration: none;
    font-family: 'FT System', var(--font-body--family), sans-serif;
    font-weight: 400;
    font-size: 14px;
    line-height: 20px;
    color: #202635;
    width: fit-content;
  }

  .cf-articles__learn-more-arrow {
    font-family: Inter, var(--font-body--family), sans-serif;
    font-weight: 500;
    font-size: 11px;
    line-height: 13px;
    text-align: center;
    color: #202635;
  }
</style>

<div class="cf-articles">
  <div class="cf-articles__scroll">
    <div class="cf-articles__container">

      {%- for article in shop.metaobjects.articles_recharge.values limit: 3 -%}
        {%- liquid
          assign article_eyebrow = article.eyebrow.value
          assign article_headline = article.headline.value
          assign article_url = article.link_url.value | default: '#'
          assign article_label = article.link_label.value | default: 'Read more'
          assign article_alt = article_headline | default: 'Article' | strip_newlines
        -%}
        <div class="cf-articles__card">
          <div class="cf-articles__media">
            {%- if article.image.value != blank -%}
              {{
                article.image.value
                | image_url: width: 624
                | image_tag:
                  loading: 'lazy',
                  widths: '312, 468, 624',
                  sizes: '312px',
                  alt: article_alt
              }}
            {%- else -%}
              <img
                src="https://cdn.shopify.com/s/files/1/1000/8959/4135/files/frame-1000005553-page-1-68526545.png?v=1780582270"
                alt="{{ article_alt | escape }}"
                width="312"
                height="175"
                loading="lazy"
              >
            {%- endif -%}
          </div>
          <div class="cf-articles__text-lockup">
            <div class="cf-articles__heading">
              <div class="cf-articles__heading-lockup">
                <p class="cf-articles__eyebrow">{{ article_eyebrow }}</p>
                <p class="cf-articles__headline">{{ article_headline }}</p>
              </div>
            </div>
            <a href="{{ article_url }}" class="cf-articles__learn-more">
              {{ article_label }}
              <span class="cf-articles__learn-more-arrow">&rarr;</span>
            </a>
          </div>
        </div>
      {%- else -%}

        <div class="cf-articles__card">
          <div class="cf-articles__media">
            <img
              src="https://cdn.shopify.com/s/files/1/1000/8959/4135/files/frame-1000005553-page-1-68526545.png?v=1780582270"
              alt="What's Really In Your Tap Water?"
              width="312"
              height="175"
              loading="lazy"
            >
          </div>
          <div class="cf-articles__text-lockup">
            <div class="cf-articles__heading">
              <div class="cf-articles__heading-lockup">
                <p class="cf-articles__eyebrow">Water 101 &bull; 5 Min Read</p>
                <p class="cf-articles__headline">What's Really In Your Tap Water? A Deep Dive Into Contaminants</p>
              </div>
            </div>
            <a href="#" class="cf-articles__learn-more">
              Read more
              <span class="cf-articles__learn-more-arrow">&rarr;</span>
            </a>
          </div>
        </div>

        <div class="cf-articles__card">
          <div class="cf-articles__media">
            <img
              src="https://cdn.shopify.com/s/files/1/1000/8959/4135/files/frame-1000005553-page-1-68526545.png?v=1780582270"
              alt="2026 Top 10 States with the Dirtiest Water"
              width="312"
              height="175"
              loading="lazy"
            >
          </div>
          <div class="cf-articles__text-lockup">
            <div class="cf-articles__heading">
              <div class="cf-articles__heading-lockup">
                <p class="cf-articles__eyebrow">Water 101 &bull; 5 Min Read</p>
                <p class="cf-articles__headline">2026 Top 10 States with the Dirtiest Water</p>
              </div>
            </div>
            <a href="#" class="cf-articles__learn-more">
              Read more
              <span class="cf-articles__learn-more-arrow">&rarr;</span>
            </a>
          </div>
        </div>

        <div class="cf-articles__card">
          <div class="cf-articles__media">
            <img
              src="https://cdn.shopify.com/s/files/1/1000/8959/4135/files/frame-1000005553-page-1-68526545.png?v=1780582270"
              alt="What's Really In Your Tap Water?"
              width="312"
              height="175"
              loading="lazy"
            >
          </div>
          <div class="cf-articles__text-lockup">
            <div class="cf-articles__heading">
              <div class="cf-articles__heading-lockup">
                <p class="cf-articles__eyebrow">Water 101 &bull; 5 Min Read</p>
                <p class="cf-articles__headline">What's Really In Your Tap Water? A Deep Dive Into Contaminants</p>
              </div>
            </div>
            <a href="#" class="cf-articles__learn-more">
              Read more
              <span class="cf-articles__learn-more-arrow">&rarr;</span>
            </a>
          </div>
        </div>

      {%- endfor -%}

    </div>
  </div>
</div>
